# WhatsApp Bot Configuration
PORT=3001

# URL of your Vercel app (e.g., https://your-app.vercel.app)
VERCEL_API_URL=https://your-app.vercel.app

# Secret key for authenticating requests between bot and Vercel
# Generate a random string and use the same value in your Vercel env vars
BOT_SECRET=your-random-secret-key-here

# Auth folder for storing WhatsApp session
AUTH_FOLDER=./auth_info
