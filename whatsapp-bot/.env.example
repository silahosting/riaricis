# WhatsApp Bot Configuration for cPanel ArenaHost
# Copy file ini jadi .env dan isi nilainya

# Port untuk bot (biasanya tidak perlu diubah)
PORT=3001

# URL website Vercel Anda
VERCEL_API_URL=https://riaricis.vercel.app

# Secret key untuk autentikasi (buat random string yang aman)
# PENTING: Gunakan nilai yang SAMA di dashboard WhatsApp website
BOT_SECRET=ganti-dengan-secret-key-random-anda

# Folder untuk menyimpan session WhatsApp (tidak perlu diubah)
AUTH_FOLDER=./session
